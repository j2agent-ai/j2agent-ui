{
  "name": "ai-system-ui",
  "private": true,
  "version": "1.0.22-dev3.1.4",
  "type": "module",
  "scripts": {
    "dev": "vite --mode development --no-open",
    "build-dev": "vite build --mode development",
    "build": "vite build --mode production",
    "build:analyze": "vite build --mode production && echo 'Open dist/report.html after build'",
    "preview": "vite preview",
    "release": "standard-version",
    "lint": "npx eslint --ext .js,.jsx,.ts,.tsx,.vue,.json src",
    "lint:fix": "npx eslint --fix --ext .js,.jsx,.ts,.tsx,.vue,.json src",
    "test:unit": "npx tsx --test src/utils/historyProgressiveRender.test.ts",
    "prepare": "husky install"
  },
  "dependencies": {
    "@plantuml/core": "^1.2026.6",
    "axios": "1.8.2",
    "crypto-js": "^4.2.0",
    "diff": "^7.0.0",
    "element-plus": "^2.9.4",
    "jsencrypt": "^3.3.2",
    "lodash-es": "~4.17.21",
    "markdown-it": "^14.1.0",
    "mermaid": "^11.12.2",
    "mitt": "^3.0.0",
    "qs": "^6.11.2",
    "sass": "^1.84.0",
    "vega": "^6.2.0",
    "vega-embed": "^7.1.0",
    "vega-lite": "^6.4.3",
    "vue": "^3.5.15",
    "vue-diff": "^1.2.4",
    "vue-router": "4.2.4",
    "xss": "~1.0.14"
  },
  "devDependencies": {
    "@commitlint/config-conventional": "~17.7.0",
    "@types/diff": "^5.2.3",
    "@types/ip": "^1.1.3",
    "@vitejs/plugin-vue": "^5.2.4",
    "@vitejs/plugin-vue-jsx": "^4.2.0",
    "commitizen": "~4.3.0",
    "commitlint": "~17.7.1",
    "cz-conventional-changelog": "~3.3.0",
    "eslint": "~8.49.0",
    "eslint-plugin-vue": "~9.18.1",
    "husky": "~8.0.3",
    "lint-staged": "~14.0.1",
    "pinia": "^2.1.7",
    "pinia-plugin-persistedstate": "^2.1.0",
    "prettier": "~3.0.3",
    "rollup-plugin-visualizer": "^5.14.0",
    "screenfull": "^6.0.2",
    "standard-version": "~9.5.0",
    "typescript": "^5.6.3",
    "unplugin-auto-import": "^19.1.0",
    "unplugin-element-plus": "^0.9.1",
    "unplugin-vue-components": "^28.4.0",
    "unplugin-vue-define-options": "~1.3.18",
    "vite": "^6.0.11",
    "vite-plugin-compression": "^0.5.1",
    "vue-tsc": "~1.8.5",
    "vue3-seamless-scroll": "^2.0.1"
  },
  "engines": {
    "node": ">=18",
    "npm": ">=9",
    "yarn": ">=1.22"
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "lint-staged": {
    "src/**/*.{vue,js,ts,jsx,tsx,json}": [
      "eslint --fix",
      "prettier --write"
    ],
    "src/**/*.md": [
      "prettier --write"
    ]
  }
}
